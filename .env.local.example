# Environment variables voor Factory Manager
# Kopieer dit bestand naar .env.local en pas de waarden aan.
# .env.local staat NIET in Git (zie .gitignore).

# Pin voor de Super Admin (Ghost) gebruiker.
# Als niet ingesteld, wordt de standaard fallback-waarde gebruikt.
VITE_GHOST_PIN=000894

# ── LICENTIE ────────────────────────────────────────────────────────────────
# Zet op 'true' om de licentiecheck te overslaan tijdens de testfase.
# VERWIJDER of zet op 'false' vóór productie go-live!
VITE_BYPASS_LICENSE=true

# Gedeeld HMAC-SHA256 secret voor client-side licentie signature verificatie.
# Wordt aangeleverd door de vendor (factory-manager.nl) bij productie activatie.
VITE_LICENSE_HMAC_SECRET=
